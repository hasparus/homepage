{
  "redirects": [
    {
      "source": "/s/:path*",
      "destination": "https://hasparus-url-shortener.builtwithdark.com/:path*"
    }
  ],
  "rewrites": [
    {
      "source": "/?:path*",
      "has": [
        {
          "type": "host",
          "value": "bear-fit.haspar.us"
        }
      ],
      "destination": "https://bear-fit.hasparus.partykit.dev/:path*",
      "trailingSlash": true
    },
    {
      "source": "",
      "has": [
        {
          "type": "host",
          "value": "bear-fit.haspar.us"
        }
      ],
      "destination": "https://bear-fit.hasparus.partykit.dev",
      "trailingSlash": true
    },
    {
      "source": "/?:path*",
      "has": [
        {
          "type": "host",
          "value": "mageworld.haspar.us"
        }
      ],
      "destination": "https://mageworld.vercel.app/:path*",
      "trailingSlash": true
    },
    {
      "source": "",
      "has": [
        {
          "type": "host",
          "value": "mageworld.haspar.us"
        }
      ],
      "destination": "https://mageworld.vercel.app",
      "trailingSlash": true
    }
  ]
}
